  # uv run pytest -q -n 4
  #
  # ## SUM: run only time-balanced part of testsuite
  # # DEP: pytest-split
  # uv run pytest -q --store-durations --splits 3 --group 1
fi

if [[ ${opts[run]:+x} ]]; then
  if [[ ${opts[jurigged]:+x} ]]; then
    exec "$venvbin/jurigged" -v -w "$here/pkg" -m miurapp "$@"
  else
    ## FAIL? seems doesn't work with uv/workspace
    #   SEE: https://github.com/astral-sh/uv/issues/13095
    # uvr miur "$@"
    exec "$venvbin/miur" "$@"
  fi
fi

